<script>
const IMGS={rr:"data:image/jpeg;base64,",k5:"data:image/jpeg;base64,",tsl:"data:image/jpeg;base64,",mal:"data:image/jpeg;base64,",ela:"data:image/jpeg;base64,"};
const fleet=[
  {name:"Land Rover Range Rover Sport 2015",cat:"Luxury SUV",img:IMGS.rr,tagline:"100% Dominant. 100% Elite.",badge:"Most Popular",gold:true,price:149,rating:5.0,trips:23,tags:["HSE 4WD","V6 Supercharged","7 Seats","GPS"]},
  {name:"Kia K5 2021",cat:"Sport Sedan",img:IMGS.k5,tagline:"100% Stylish. 100% Elegance.",badge:"Fan Favorite",gold:false,price:79,rating:5.0,trips:12,tags:["LX Auto FWD","Sport Trim","Backup Cam"]},
  {name:"Tesla Model 3 2019",cat:"Electric Vehicle",img:IMGS.tsl,tagline:"100% Electric. 100% Future.",badge:"EV",gold:false,price:99,rating:5.0,trips:6,tags:["Autopilot","340mi Range","Zero Emissions"]},
  {name:"Chevrolet Malibu 2021",cat:"Everyday Sedan",img:IMGS.mal,tagline:"100% Efficient. 100% Modern.",badge:"Best Value",gold:true,price:69,rating:5.0,trips:1,tags:["LT Trim","FWD","Backup Cam"]},
  {name:"Hyundai Elantra 2022",cat:"Compact Sedan",img:IMGS.ela,tagline:"100% Efficient. 100% Modern.",badge:"Newest",gold:false,price:65,rating:4.75,trips:4,tags:["SE Trim","Lane Assist","FWD"]},
];
const faqs=[
  {icon:"🪪",q:"What are the requirements to rent?",a:"You must be 21+ with a valid driver's license. Drivers aged 21–24 pay a Young Driver fee of +$15/day. A refundable security deposit ($300–$500 depending on vehicle) is required at pickup along with a signed DocuSign rental agreement."},
  {icon:"💰",q:"What is your security deposit policy?",a:"Deposits range from $300 (sedans) to $500 (Range Rover/Tesla). Released within 3 business days after return, minus any applicable fees for damage, excess mileage, cleaning, or late returns."},
  {icon:"🛣️",q:"What are the mileage limits?",a:"Every rental includes 200 miles/day at no extra charge. Add Unlimited Mileage (+$25/day) for worry-free road trips. Overages without the upgrade are billed at $0.30/mile."},
  {icon:"🚚",q:"Do you offer delivery and pickup?",a:"Yes — free delivery within 15 miles of 9100 Merrill Rd, Jacksonville FL 32225. Hotel and airport delivery available. Contact us to confirm details for your exact location."},
  {icon:"🔄",q:"What is your cancellation policy?",a:"Cancellations 48+ hours before pickup: full deposit refund. Less than 24 hours: deposit forfeited. Free reschedule up to 24 hours before pickup. A small processing fee may apply on refunds."},
  {icon:"🛡️",q:"What insurance options are available?",a:"You can use your own personal auto insurance — just verify it covers non-owned vehicles. We also offer Basic Protection (+$15/day, $500 deductible) and Premium Protection (+$25/day, $0 deductible) as optional add-ons."},
  {icon:"⏰",q:"Can I extend my rental?",a:"Absolutely — just reach out before your current rental ends and we'll extend it if the vehicle is available. Extensions are charged at your original daily rate."},
  {icon:"💳",q:"What payment methods do you accept?",a:"Cash App, Zelle, Venmo, PayPal, and Apple Pay. All payments confirmed before vehicle handoff. No personal checks or cryptocurrency."},
];
const reviews=[
  {q:"Car was spotless and Corey responded instantly. Way better than any rental agency.",n:"Marcus T.",d:"Mar 2026",i:"MT"},
  {q:"The Range Rover was exactly as described. Ready early, super clean. Highest recommendation.",n:"Jasmine R.",d:"Feb 2026",i:"JR"},
  {q:"Smooth from start to finish. The K5 drove beautifully and the price was unbeatable.",n:"Derek P.",d:"Jan 2026",i:"DP"},
  {q:"Used the Tesla for a weekend trip. Perfect experience. Already booked again.",n:"Aaliyah M.",d:"Mar 2026",i:"AM"},
  {q:"Best rental in Jacksonville. No airport fees, no hidden charges. Very professional.",n:"Kevin L.",d:"Feb 2026",i:"KL"},
  {q:"The Elantra was great all week. Immaculate car, effortless from start to finish.",n:"Tanya B.",d:"Jan 2026",i:"TB"},
];

document.getElementById("fleetGrid").innerHTML=fleet.map((c,i)=>`
  <div class="car-card reveal d${(i%4)+1}">
    <div class="car-thumb">
      <img src="${c.img}" alt="${c.name}" loading="lazy">
      <div class="pill pill-${c.gold?'gold':'dark'}">${c.badge}</div>
      <div class="car-tagline">${c.tagline}</div>
    </div>
    <div class="car-body">
      <div class="car-cat">${c.cat}</div>
      <div class="car-name">${c.name}</div>
      <div class="tags">${c.tags.map(t=>`<span class="tag">${t}</span>`).join("")}</div>
      <div class="car-footer">
        <div class="car-price">$${c.price}<sub> / day</sub></div>
        <div class="car-rating"><span class="star">★</span> ${c.rating} <span style="font-size:11px;color:var(--text-dim)">(${c.trips})</span></div>
      </div>
      <a href="#" class="btn-reserve" onclick="reserveCar('${c.name}','${c.price}');return false;">Reserve This Vehicle →</a>
    </div>
  </div>`).join("");

document.getElementById("faqList").innerHTML=faqs.map((f,i)=>`
  <div class="faq-item" id="faq${i}">
    <div class="faq-q" onclick="toggleFaq(${i})">
      <div class="faq-ql"><div class="faq-qi">${f.icon}</div><div class="faq-qt">${f.q}</div></div>
      <div class="faq-arr">▼</div>
    </div>
    <div class="faq-a">${f.a}</div>
  </div>`).join("");

document.getElementById("reviewsGrid").innerHTML=reviews.map((r,i)=>`
  <div class="review reveal d${(i%3)+1}">
    <div class="review-stars">★★★★★</div>
    <p class="review-text">"${r.q}"</p>
    <div class="review-author"><div class="avatar">${r.i}</div><div><div class="author-name">${r.n}</div><div class="author-date">${r.d}</div></div></div>
  </div>`).join("");

const today=new Date().toISOString().split("T")[0];
document.querySelectorAll('input[type="date"]').forEach(el=>el.min=today);

function toggleTheme(){
  const h=document.documentElement,dark=h.getAttribute("data-theme")==="dark";
  h.setAttribute("data-theme",dark?"light":"dark");
  const l=document.getElementById("modeLabel");if(l)l.textContent=dark?"Dark":"Light";
  localStorage.setItem("eclps-theme",dark?"light":"dark");
}
const saved=localStorage.getItem("eclps-theme");
if(saved)document.documentElement.setAttribute("data-theme",saved);

const sel=new Set();
function toggleAddon(el,name){el.classList.toggle("on");sel.has(name)?sel.delete(name):sel.add(name)}

function openModal(){
  const v=document.getElementById("vehicleSelect").value,p=document.getElementById("pickupDate").value,r=document.getElementById("returnDate").value,n=document.getElementById("heroName").value;
  document.getElementById("mCar").textContent=v||"No vehicle selected";
  document.getElementById("mDates").textContent=(p&&r)?`${p} → ${r}`:"Dates not selected";
  document.getElementById("mAddons").textContent=sel.size?"Add-ons: "+[...sel].join(", "):"";
  if(p)document.getElementById("mPickup").value=p;if(r)document.getElementById("mReturn").value=r;if(n)document.getElementById("mName").value=n;
  document.getElementById("overlay").classList.add("open");
}
function reserveCar(name,price){
  document.getElementById("mCar").textContent=`${name} — $${price}/day`;
  document.getElementById("mDates").textContent="Select your dates below";
  document.getElementById("mAddons").textContent="";
  document.getElementById("overlay").classList.add("open");
}
function closeModal(){document.getElementById("overlay").classList.remove("open")}
function submitForm(){
  document.getElementById("modalContent").innerHTML=`<div class="success"><div class="success-icon">✅</div><h3>Request Sent!</h3><p>We'll reach out within a few hours to confirm availability and send your DocuSign agreement. Check your phone and email.</p><button class="btn-ms" onclick="closeModal()" style="max-width:180px;margin:0 auto;display:block">Done</button></div>`;
}
document.getElementById("overlay").addEventListener("click",e=>{if(e.target===document.getElementById("overlay"))closeModal()});
function toggleFaq(i){document.getElementById("faq"+i).classList.toggle("open")}
function toggleMenu(){document.getElementById("mobileMenu").classList.toggle("open")}
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");obs.unobserve(e.target)}})},{threshold:0.07});
document.querySelectorAll(".reveal").forEach(el=>obs.observe(el));
</script>

