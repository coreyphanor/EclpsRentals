<!DOCTYPE html>

<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ECLPS Rentals — Private Car Rental · Jacksonville, FL</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   CSS CUSTOM PROPERTIES
══════════════════════════════════════ */
:root { --tt: background-color 0.32s ease, color 0.32s ease, border-color 0.32s ease, box-shadow 0.32s ease; }

[data-theme=“dark”] {
–bg:          #080C18;
–bg2:         #0B1022;
–surface:     #0F1628;
–surface2:    #162035;
–surface3:    #1C2840;
–border:      rgba(201,168,76,0.13);
–border2:     rgba(201,168,76,0.22);
–gold:        #C9A84C;
–gold-lt:     #E2C06A;
–gold-dim:    rgba(201,168,76,0.13);
–gold-bdr:    rgba(201,168,76,0.30);
–text:        #EDE8D6;
–text-muted:  rgba(237,232,214,0.58);
–text-dim:    rgba(237,232,214,0.28);
–nav-bg:      rgba(8,12,24,0.96);
–sc:          0 2px 20px rgba(0,0,0,0.4);
–sh:          0 16px 56px rgba(0,0,0,0.6);
–tk-bg:       #162035;
–tk-knob:     #C9A84C;
–footer-bg:   #040608;
}

[data-theme=“light”] {
–bg:          #F5F2E8;
–bg2:         #EDE8D9;
–surface:     #FFFFFF;
–surface2:    #F0EBE0;
–surface3:    #E6DFCE;
–border:      rgba(8,13,40,0.09);
–border2:     rgba(8,13,40,0.17);
–gold:        #9A6F0A;
–gold-lt:     #B58312;
–gold-dim:    rgba(154,111,10,0.10);
–gold-bdr:    rgba(154,111,10,0.25);
–text:        #06091A;
–text-muted:  rgba(6,9,26,0.56);
–text-dim:    rgba(6,9,26,0.30);
–nav-bg:      rgba(245,242,232,0.96);
–sc:          0 2px 16px rgba(8,13,40,0.07);
–sh:          0 12px 40px rgba(8,13,40,0.13);
–tk-bg:       #E6DFCE;
–tk-knob:     #08092A;
–footer-bg:   #06091A;
}

/* ══════════════════════════════════════
BASE
══════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:‘Inter’,sans-serif;background:var(–bg);color:var(–text);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;transition:var(–tt);overflow-x:hidden}

/* ══════════════════════════════════════
MARBLE BACKGROUNDS
══════════════════════════════════════ */
/* Used on: Hero, CTA */
.tex-dark{
background-image:url(‘data:image/jpeg;base64,’);
background-size:cover;background-position:center;
position:relative;
}
/* Used on: Add-Ons */
.tex-bright{
background-image:url(‘data:image/jpeg;base64,’);
background-size:cover;background-position:center;
position:relative;
}
/* Dark overlay — tuned per texture */
.tex-dark::before{
content:’’;position:absolute;inset:0;pointer-events:none;z-index:0;
background:linear-gradient(135deg,rgba(4,6,20,0.80) 0%,rgba(4,8,24,0.72) 50%,rgba(4,6,18,0.78) 100%);
}
.tex-bright::before{
content:’’;position:absolute;inset:0;pointer-events:none;z-index:0;
background:linear-gradient(135deg,rgba(4,10,28,0.75) 0%,rgba(2,8,22,0.68) 50%,rgba(4,10,28,0.74) 100%);
}
.tex-inner{position:relative;z-index:1}

/* ══════════════════════════════════════
THEME TOGGLE
══════════════════════════════════════ */
.theme-toggle{display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none;flex-shrink:0}
.toggle-track{width:44px;height:24px;background:var(–tk-bg);border:1.5px solid var(–border2);border-radius:100px;position:relative;transition:background .3s,border-color .3s;flex-shrink:0}
.toggle-knob{width:16px;height:16px;background:var(–tk-knob);border-radius:50%;position:absolute;top:50%;left:3px;transform:translateY(-50%);transition:left .28s cubic-bezier(.34,1.56,.64,1),background .3s}
[data-theme=“light”] .toggle-knob{left:21px}
.ti{font-size:13px;line-height:1}

/* ══════════════════════════════════════
NAV
══════════════════════════════════════ */
nav{position:sticky;top:0;z-index:300;height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 48px;background:var(–nav-bg);border-bottom:1px solid var(–border);backdrop-filter:blur(20px);transition:var(–tt)}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.nav-logo img{width:32px;height:32px;object-fit:contain;border-radius:4px}
.logo-text{font-family:‘Syne’,sans-serif;font-size:15px;font-weight:800;letter-spacing:2px;color:var(–text);transition:color .3s}
.logo-text em{font-style:normal;color:var(–gold)}
.nav-center{display:flex;gap:22px;list-style:none;align-items:center}
.nav-center a{font-size:13px;color:var(–text-muted);text-decoration:none;transition:color .2s}
.nav-center a:hover{color:var(–text)}
.nav-right{display:flex;align-items:center;gap:14px}
.btn-nav{background:var(–gold);color:var(–bg)!important;font-weight:700!important;padding:9px 20px;border-radius:7px;font-size:13px;text-decoration:none;transition:background .2s;white-space:nowrap}
.btn-nav:hover{background:var(–gold-lt)}
.nav-ham{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;flex-shrink:0}
.nav-ham span{width:20px;height:2px;background:var(–text);border-radius:2px;transition:background .3s}
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;background:var(–nav-bg);border-bottom:1px solid var(–border);flex-direction:column;z-index:299;backdrop-filter:blur(20px)}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:15px;color:var(–text-muted);text-decoration:none;padding:13px 20px;border-bottom:1px solid var(–border);transition:color .2s,background .2s}
.mobile-menu a:hover{color:var(–text);background:var(–surface2)}
.mob-book{margin:10px 20px 10px!important;background:var(–gold)!important;color:var(–bg)!important;text-align:center!important;border-radius:8px!important;padding:13px!important;font-weight:700!important;border-bottom:none!important}
.mob-theme{display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid var(–border);font-size:13px;color:var(–text-muted)}

/* ══════════════════════════════════════
HERO
══════════════════════════════════════ */
.hero-outer{border-bottom:1px solid var(–border)}
.hero-inner{padding:88px 48px 72px;display:grid;grid-template-columns:1fr 415px;gap:52px;align-items:start;max-width:1200px;margin:0 auto}
.eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.16);border:1px solid rgba(201,168,76,0.38);color:#E2C06A;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;padding:5px 14px;border-radius:100px;margin-bottom:22px;max-width:100%}
.eyebrow-dot{width:6px;height:6px;background:#C9A84C;border-radius:50%;animation:blink 2s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.hero-h1{font-family:‘Syne’,sans-serif;font-size:clamp(38px,5.5vw,68px);font-weight:800;line-height:1.04;letter-spacing:-1.5px;color:#EDE8D6;margin-bottom:18px;word-break:break-word;width:100%}
.hero-h1 em{font-style:normal;color:#C9A84C}
.hero-sub-txt{font-size:15px;font-weight:300;color:rgba(237,232,214,0.72);max-width:430px;line-height:1.8;margin-bottom:32px}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px}
.btn-primary{background:var(–gold);color:var(–bg);padding:13px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;transition:background .2s;border:none;cursor:pointer;font-family:‘Inter’,sans-serif;display:inline-block}
.btn-primary:hover{background:var(–gold-lt)}
.btn-secondary{background:rgba(255,255,255,0.08);color:#EDE8D6;padding:13px 28px;border-radius:8px;font-size:14px;font-weight:400;text-decoration:none;border:1px solid rgba(237,232,214,0.20);backdrop-filter:blur(4px);transition:border-color .2s,background .2s}
.btn-secondary:hover{border-color:rgba(201,168,76,0.45);background:rgba(201,168,76,0.09)}
.hero-stats{display:flex;gap:36px;flex-wrap:wrap;padding-top:28px;border-top:1px solid rgba(201,168,76,0.18)}
.stat-val{font-family:‘Syne’,sans-serif;font-size:26px;font-weight:800;color:#EDE8D6;line-height:1}
.stat-val em{font-style:normal;color:#C9A84C}
.stat-lbl{font-size:11px;color:rgba(237,232,214,0.52);margin-top:3px}

/* Booking card */
.bcard{background:rgba(10,14,30,0.78);border:1px solid rgba(201,168,76,0.22);border-radius:16px;padding:26px;backdrop-filter:blur(14px)}
[data-theme=“light”] .bcard{background:rgba(255,255,255,0.90);border-color:rgba(8,13,40,0.14);backdrop-filter:blur(14px)}
.bcard-title{font-family:‘Syne’,sans-serif;font-size:16px;font-weight:800;color:#EDE8D6;margin-bottom:18px}
[data-theme=“light”] .bcard-title{color:var(–text)}
.bform{display:flex;flex-direction:column;gap:11px}
.bform label{font-size:10px;font-weight:700;color:rgba(237,232,214,0.55);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;display:block}
[data-theme=“light”] .bform label{color:var(–text-muted)}
.bform input,.bform select{width:100%;background:rgba(22,32,53,0.92);border:1px solid rgba(201,168,76,0.16);border-radius:8px;color:#EDE8D6;font-family:‘Inter’,sans-serif;font-size:14px;padding:11px 14px;outline:none;appearance:none;transition:border-color .2s}
[data-theme=“light”] .bform input,[data-theme=“light”] .bform select{background:var(–surface2);border-color:var(–border);color:var(–text)}
.bform input::placeholder{color:rgba(237,232,214,0.28)}
[data-theme=“light”] .bform input::placeholder{color:var(–text-dim)}
.bform input:focus,.bform select:focus{border-color:#C9A84C}
.bform select option{background:#0F1628;color:#EDE8D6}
[data-theme=“light”] .bform select option{background:#fff;color:#06091A}
.brow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn-book{width:100%;padding:13px;background:#C9A84C;color:var(–bg);border:none;border-radius:8px;font-family:‘Inter’,sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:background .2s;margin-top:4px}
.btn-book:hover{background:#E2C06A}
.bcard-note{text-align:center;font-size:11px;color:rgba(237,232,214,0.32);margin-top:10px}
[data-theme=“light”] .bcard-note{color:var(–text-dim)}
.addon-row{display:flex;flex-direction:column;gap:6px}
.addon-toggle{display:flex;align-items:center;justify-content:space-between;background:rgba(22,32,53,0.85);border:1px solid rgba(201,168,76,0.13);border-radius:8px;padding:9px 11px;cursor:pointer;transition:border-color .2s,background .2s;user-select:none}
[data-theme=“light”] .addon-toggle{background:var(–surface2);border-color:var(–border)}
.addon-toggle:hover{border-color:rgba(201,168,76,0.38)}
.addon-toggle.on{border-color:#C9A84C;background:rgba(201,168,76,0.10)}
.addon-l{display:flex;align-items:center;gap:8px}
.addon-emoji{font-size:14px}
.addon-nm{font-size:12px;font-weight:500;color:#EDE8D6}
[data-theme=“light”] .addon-nm{color:var(–text)}
.addon-pr{font-size:11px;font-weight:600;color:#C9A84C}
.addon-chk{width:16px;height:16px;border:1.5px solid rgba(201,168,76,0.28);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;transition:all .2s;color:transparent}
.addon-toggle.on .addon-chk{background:#C9A84C;border-color:#C9A84C;color:var(–bg);font-weight:700}

/* ══════════════════════════════════════
TRUST BAR
══════════════════════════════════════ */
.trust{border-top:1px solid var(–border);border-bottom:1px solid var(–border);display:flex;justify-content:center;gap:0;overflow-x:auto;background:var(–surface);-webkit-overflow-scrolling:touch;scrollbar-width:none;transition:var(–tt)}
.trust::-webkit-scrollbar{display:none}
.trust-item{display:flex;align-items:center;gap:8px;padding:16px 26px;border-right:1px solid var(–border);flex-shrink:0;white-space:nowrap;transition:background .2s}
.trust-item:hover{background:var(–surface2)}
.trust-item:last-child{border-right:none}
.trust-icon{font-size:14px}
.trust-label{font-size:13px;color:var(–text-muted)}
.trust-label strong{color:var(–text);font-weight:600}

/* ══════════════════════════════════════
SECTION SYSTEM
══════════════════════════════════════ */
.section{padding:88px 48px;max-width:1200px;margin:0 auto;width:100%}
.sfull{padding:88px 48px;transition:var(–tt)}
.bg-s{background:var(–surface);transition:var(–tt)}
.bg-s2{background:var(–bg2);transition:var(–tt)}
.sec-label{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(–gold);margin-bottom:8px}
.sec-title{font-family:‘Syne’,sans-serif;font-size:clamp(26px,3.5vw,44px);font-weight:800;letter-spacing:-.5px;color:var(–text);margin-bottom:8px;transition:color .3s;word-break:break-word}
.sec-sub{font-size:15px;color:var(–text-muted);font-weight:300;max-width:520px;line-height:1.75;transition:color .3s}

/* ══════════════════════════════════════
FLEET
══════════════════════════════════════ */
.fleet-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(310px,100%),1fr));gap:20px;margin-top:44px}
.car-card{background:var(–surface);border:1.5px solid var(–border);border-radius:16px;overflow:hidden;box-shadow:var(–sc);transition:transform .28s,border-color .28s,box-shadow .3s,var(–tt)}
.car-card:hover{transform:translateY(-5px);border-color:var(–gold-bdr);box-shadow:var(–sh)}
.car-thumb{height:215px;overflow:hidden;position:relative}
.car-thumb img{width:100%;height:100%;object-fit:cover;object-position:center 42%;transition:transform .45s}
.car-card:hover .car-thumb img{transform:scale(1.05)}
.car-thumb::after{content:’’;position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(0,0,0,0.6) 100%);pointer-events:none}
.pill{position:absolute;top:12px;left:12px;font-size:10px;font-weight:700;letter-spacing:.5px;padding:4px 11px;border-radius:100px;z-index:1}
.pill-dark{background:rgba(0,0,0,0.65);color:#EDE8D6;border:1px solid rgba(255,255,255,0.18);backdrop-filter:blur(6px)}
.pill-gold{background:#C9A84C;color:#08091A}
.car-tagline{position:absolute;bottom:12px;left:14px;right:14px;z-index:1;font-size:11px;font-weight:500;color:rgba(255,255,255,0.82);font-style:italic}
.car-body{padding:20px 20px 22px}
.car-cat{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(–gold);margin-bottom:4px}
.car-name{font-family:‘Syne’,sans-serif;font-size:18px;font-weight:800;letter-spacing:-.3px;margin-bottom:12px;color:var(–text);transition:color .3s;word-break:break-word}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px}
.tag{font-size:11px;font-weight:500;padding:3px 10px;border-radius:100px;background:var(–surface2);color:var(–text-muted);border:1px solid var(–border);transition:var(–tt)}
.car-footer{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid var(–border)}
.car-price{font-family:‘Syne’,sans-serif;font-size:24px;font-weight:800;color:var(–text)}
.car-price sub{font-family:‘Inter’,sans-serif;font-size:12px;font-weight:400;color:var(–text-muted);vertical-align:baseline}
.car-rating{font-size:13px;color:var(–text-muted);display:flex;align-items:center;gap:5px}
.star{color:#F5A623}
.btn-reserve{display:block;text-align:center;margin-top:14px;padding:11px;background:var(–surface2);color:var(–text);border:1.5px solid var(–border);border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.btn-reserve:hover{background:var(–gold);color:var(–bg);border-color:transparent}

/* ══════════════════════════════════════
ADD-ONS (marble texture bg)
══════════════════════════════════════ */
.addons-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(258px,1fr));gap:16px;margin-top:44px}
.addon-card{background:rgba(8,12,28,0.72);border:1.5px solid rgba(201,168,76,0.22);border-radius:14px;padding:26px;backdrop-filter:blur(10px);transition:border-color .2s}
.addon-card:hover{border-color:rgba(201,168,76,0.52)}
.addon-card-icon{font-size:26px;margin-bottom:14px}
.addon-card h4{font-family:‘Syne’,sans-serif;font-size:15px;font-weight:700;margin-bottom:7px;color:#EDE8D6}
.addon-card p{font-size:13px;color:rgba(237,232,214,0.68);line-height:1.7;margin-bottom:14px}
.addon-pb{display:inline-block;background:rgba(201,168,76,0.16);border:1px solid rgba(201,168,76,0.38);color:#E2C06A;font-size:13px;font-weight:700;padding:4px 12px;border-radius:100px}

/* On marble, always use white-ish text regardless of theme */
.tex-bright .sec-label{color:#E2C06A}
.tex-bright .sec-title{color:#EDE8D6}
.tex-bright .sec-sub{color:rgba(237,232,214,0.72)}

/* ══════════════════════════════════════
HOW IT WORKS
══════════════════════════════════════ */
.steps-wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:44px;border-radius:16px;overflow:hidden;border:1.5px solid var(–border)}
.step{background:var(–surface);padding:32px 24px;transition:background .2s,var(–tt)}
.step:hover{background:var(–surface2)}
.step-num{font-family:‘Syne’,sans-serif;font-size:12px;font-weight:700;color:var(–gold);letter-spacing:1px;margin-bottom:14px;display:flex;align-items:center;gap:10px}
.step-num::after{content:’’;flex:1;height:1px;background:var(–gold-bdr)}
.step-icon{font-size:24px;margin-bottom:12px}
.step h4{font-family:‘Syne’,sans-serif;font-size:15px;font-weight:700;margin-bottom:8px;color:var(–text);transition:color .3s}
.step p{font-size:13px;color:var(–text-muted);line-height:1.75}

/* ══════════════════════════════════════
FEATURES
══════════════════════════════════════ */
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:44px}
.feature{background:var(–surface);border:1.5px solid var(–border);border-radius:14px;padding:28px;transition:border-color .2s,var(–tt);box-shadow:var(–sc)}
.feature:hover{border-color:var(–gold-bdr)}
.feature-icon{font-size:22px;margin-bottom:14px}
.feature h4{font-family:‘Syne’,sans-serif;font-size:15px;font-weight:700;margin-bottom:7px;color:var(–text);transition:color .3s}
.feature p{font-size:13px;color:var(–text-muted);line-height:1.75}

/* ══════════════════════════════════════
FAQ  — FULLY READABLE, HIGH CONTRAST
══════════════════════════════════════ */
.faq-section{background:var(–bg2);transition:var(–tt)}
.faq-list{margin-top:44px;display:flex;flex-direction:column;gap:4px;max-width:820px}
.faq-item{
background:var(–surface);
border:1.5px solid var(–border);
border-radius:12px;overflow:hidden;
transition:border-color .25s,var(–tt);
box-shadow:var(–sc);
}
.faq-item.open{border-color:var(–gold-bdr)}
.faq-q{
display:flex;align-items:center;justify-content:space-between;
padding:18px 20px;cursor:pointer;gap:16px;
transition:background .2s;user-select:none;
}
.faq-q:hover{background:var(–surface2)}
.faq-ql{display:flex;align-items:center;gap:12px;flex:1;min-width:0}
.faq-qi{
width:34px;height:34px;flex-shrink:0;
background:var(–gold-dim);border:1px solid var(–gold-bdr);
border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:14px;
transition:var(–tt);
}
.faq-qt{
font-size:14px;font-weight:600;
color:var(–text);          /* ← explicit: never inherits wrong color */
transition:color .3s;
line-height:1.4;
}
.faq-arr{
width:24px;height:24px;flex-shrink:0;
border:1.5px solid var(–border2);border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:9px;color:var(–text-muted);
transition:transform .3s,background .2s,border-color .2s,color .2s;
}
.faq-item.open .faq-arr{transform:rotate(180deg);background:var(–gold-dim);border-color:var(–gold-bdr);color:var(–gold)}
/* Answer text — explicit color guarantee */
.faq-a{
display:none;
padding:0 20px 18px 66px;
font-size:14px;line-height:1.82;
color:var(–text-muted);  /* ← explicit */
